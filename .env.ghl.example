# GoHighLevel Integration Environment Variables
# Required for sign-up form → sub-account creation flow

# ============================================
# REQUIRED: GoHighLevel Agency Configuration
# ============================================

# Your Agency-level Private Integration Token from GoHighLevel
# Location in GHL: Settings → Integrations → Private Integration
# Requires: Agency Pro ($497) plan
# Scopes needed: locations.write, users.write (and optionally locations.read for debugging)
# Type: Agency-level Private Integration Token (NOT legacy "Agency API Token")
GHL_AGENCY_PRIVATE_INTEGRATION_TOKEN=your_agency_private_integration_token_here

# Your agency/company ID in GoHighLevel
# Format: Long alphanumeric string like "naA8FvnrZl2VW8iy0AQB"
# NOT the 7-digit Relationship Number (e.g., 1-234-567)
# How to find: Run GET /locations/search?limit=1 with your token and look for "companyId"
GHL_COMPANY_ID=your_company_id_here

# ============================================
# OPTIONAL: User Creation & Security
# ============================================

# Override password for newly created users (optional)
# If not set, a secure random password is generated automatically
# Users will need to reset their password via "Forgot Password" flow
GHL_DEFAULT_USER_PASSWORD=

# Webhook signature verification secret (optional but recommended)
# Set this in your FastPay webhook configuration
# If not set or set to placeholder, signature verification is skipped
GHL_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Separate token for user creation (if different from main token)
# Only needed if you have different scopes/permissions for user management
GHL_AGENCY_PRIVATE_INTEGRATION_TOKEN_USER_CREATION=

# ============================================
# REQUIRED: Email Notifications
# ============================================

# Resend API Key for sending welcome emails and notifications
# Get your API key from: https://resend.com/api-keys
# Make sure your domain (trueflow.ai) is verified in Resend dashboard
RESEND_API_KEY=re_YourResendApiKeyHere

# ============================================
# REQUIRED: Application URLs
# ============================================

# Your application's public URL (used by webhooks to call internal APIs)
# Production: https://trueflow.ai
# Staging: https://your-staging-url.railway.app
# Local: http://localhost:3000
NEXT_PUBLIC_LANDING_URL=https://trueflow.ai

# ============================================
# FastPay Payment Link Configuration
# ============================================
# These are hardcoded in the sign-up form (app/sign-up/page.tsx)
# Standard plan: 6920f7f2bbe219eb5e3624d1 ($297/mo)
# With Success Manager: 6920f847802b2ce38d6b0f8e ($444/mo)
#
# Webhook URL to configure in FastPay:
# https://trueflow.ai/api/webhooks/ghl
#
# Webhook events to enable:
# - payment.succeeded
# - InvoicePaid
# - OrderCompleted
# - order.completed
