# Email Configuration for Lead Notifications
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_YourResendApiKeyHere

# Admin Dashboard Authentication
# Access the admin dashboard at /admin with these credentials
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the RESEND_API_KEY value with your actual Resend API key
# 3. Set a strong ADMIN_PASS for the admin dashboard
# 4. Make sure your domain (trueflow.ai) is verified in your Resend dashboard
# 5. The automation will send emails to griffin@trueflow.ai and matt@trueflow.ai

# Note: .env.local is automatically ignored by git for security